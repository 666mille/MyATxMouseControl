{
  "name": "myatxmousecontrol",
  "version": "1.0.0",
  "description": "Stream Deck plugin for ATK X1 Ultimate mouse (battery, DPI, polling rate, sensor mode)",
  "author": "holgermilz",
  "repository": "https://github.com/666mille/MyATxMouseControl",
  "license": "MIT",
  "type": "module",
  "scripts": {
    "build": "rollup -c && node scripts/copy-native.mjs",
    "watch": "rollup -c -w --watch.onEnd=\"streamdeck restart com.holgermilz.myatxmousecontrol\"",
    "pack": "rollup -c && streamdeck pack com.holgermilz.myatxmousecontrol.sdPlugin"
  },
  "dependencies": {
    "@elgato/streamdeck": "^1.2.1",
    "node-hid": "^3.1.2"
  },
  "devDependencies": {
    "@rollup/plugin-commonjs": "^28.0.0",
    "@rollup/plugin-node-resolve": "^15.3.0",
    "@rollup/plugin-terser": "^0.4.4",
    "@rollup/plugin-typescript": "^12.1.0",
    "@types/node": "^20.16.0",
    "rollup": "^4.22.0",
    "tslib": "^2.7.0",
    "typescript": "^5.6.0"
  }
}
